[{
  $match: {
    status: 'NORMAL',
    fuid: ObjectId('#{userId}')
  }
}, {
  $lookup: {
    from: 'User',
    localField: 'suid',
    foreignField: '_id',
    as: 'friend'
  }
}, {
  $unwind: {
    path: '$friend',
    preserveNullAndEmptyArrays: false
  }
}, {
  $project: {
    fId: '$suid',
    fId: '$friend._id',
    fPhone: "$friend.phone",
    fNickname: "$friend.nickname",
    fAvatar: "$friend.avatar",
    createTime: 1

  }
}]